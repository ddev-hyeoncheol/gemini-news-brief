# Cloud Build source upload allowlist.
#
# Exclude everything, re-include Docker build inputs, then re-apply
# shared generated-file exclusions from `.gitignore`.

# Exclude everything by default.
*

# Docker build inputs.
!Dockerfile
!requirements.txt
!src/
!src/**

# Non-runtime management directories remain excluded.
cloudbuild/
terraform/

# Re-apply shared ignore rules after re-including `src/`.
#!include:.gitignore

# Upload-only exclusions not covered by `.gitignore`.
src/simple_test.py
